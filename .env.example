# LLM provider: modal-vllm or openai.
LLM_PROVIDER=modal-vllm

# Modal vLLM endpoint. Use the base endpoint; /v1 is also accepted.
DEFAULT_ENDPOINT=https://your-workspace--your-vllm-app.modal.run
VLLM_MODEL=llm
VLLM_API_KEY=EMPTY

# OpenAI settings, used when LLM_PROVIDER=openai or --provider openai.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
